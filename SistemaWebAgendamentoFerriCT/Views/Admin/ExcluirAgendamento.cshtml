@model SistemaWebAgendamentoFerriCT.Models.Agendamento

@{
    ViewBag.Title = "Excluir Agendamento";
    ViewBag.ActivePage = "agendamentos";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .page-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 28px;
        flex-wrap: wrap;
        gap: 16px;
        animation: fadeUp 0.4s ease forwards;
    }

    .page-eyebrow {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--danger);
        font-weight: 700;
        margin-bottom: 4px;
    }

    .page-title {
        font-family: 'Bebas Neue',sans-serif;
        font-size: 2rem;
        letter-spacing: 1px;
        line-height: 1;
    }

    .confirm-card {
        background: var(--bg-card);
        border: 1px solid rgba(224,80,80,0.25);
        border-radius: var(--radius-md);
        overflow: hidden;
        max-width: 520px;
        animation: fadeUp 0.5s ease forwards;
    }

    .confirm-header {
        padding: 18px 24px;
        border-bottom: 1px solid rgba(224,80,80,0.15);
        display: flex;
        align-items: center;
        gap: 10px;
        background: rgba(224,80,80,0.06);
    }

    .confirm-icon {
        width: 36px;
        height: 36px;
        background: rgba(224,80,80,0.15);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--danger);
    }

    .confirm-title {
        font-weight: 700;
        font-size: 0.95rem;
        color: var(--danger);
    }

    .confirm-body {
        padding: 28px 24px;
    }

    .info-block {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 16px;
        margin-bottom: 20px;
    }

    .info-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.875rem;
    }

        .info-row:last-child {
            border: none;
        }

        .info-row i {
            color: var(--accent);
            width: 16px;
        }

    .info-label {
        color: var(--text-secondary);
        min-width: 80px;
        font-size: 0.78rem;
    }

    .info-val {
        font-weight: 600;
    }

    .warning-text {
        color: var(--text-secondary);
        font-size: 0.85rem;
        line-height: 1.6;
        margin-bottom: 24px;
    }

        .warning-text strong {
            color: #ff8a8a;
        }

    .confirm-actions {
        display: flex;
        gap: 10px;
    }

    .btn-delete {
        flex: 1;
        background: rgba(224,80,80,0.9);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        padding: 13px;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'DM Sans',sans-serif;
    }

        .btn-delete:hover {
            background: var(--danger);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(224,80,80,0.3);
        }

    .btn-cancel {
        background: transparent;
        color: var(--text-secondary);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 13px 20px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-cancel:hover {
            color: var(--text-primary);
        }
</style>

<div class="page-header">
    <div>
        <div class="page-eyebrow">Atenção — Ação Irreversível</div>
        <div class="page-title">EXCLUIR AGENDAMENTO</div>
    </div>
    <a href="/Admin/Agendamentos" class="btn-outline-gold"><i class="bi bi-arrow-left"></i> Voltar</a>
</div>

<div class="confirm-card">
    <div class="confirm-header">
        <div class="confirm-icon"><i class="bi bi-trash-fill"></i></div>
        <div class="confirm-title">Confirmar Exclusão</div>
    </div>
    <div class="confirm-body">

        <div class="info-block">
            <div class="info-row">
                <i class="bi bi-person"></i>
                <span class="info-label">Aluno</span>
                <span class="info-val">@Model.Cliente?.Nome</span>
            </div>
            <div class="info-row">
                <i class="bi bi-calendar3"></i>
                <span class="info-label">Data</span>
                <span class="info-val">@Model.DataAula.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="info-row">
                <i class="bi bi-clock"></i>
                <span class="info-label">Horário</span>
                <span class="info-val">@Model.HorarioTurma?.HoraInicio.ToString("hh\:mm")</span>
            </div>
            <div class="info-row">
                <i class="bi bi-tag"></i>
                <span class="info-label">Status</span>
                <span class="info-val">@Model.Status</span>
            </div>
        </div>

        <p class="warning-text">
            Tem certeza que deseja excluir este agendamento?<br>
            <strong>Esta ação não pode ser desfeita.</strong>
        </p>

        @using (Html.BeginForm("ExcluirAgendamento", "Admin", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.AgendamentoId" />

            <div class="confirm-actions">
                <a href="/Admin/Agendamentos" class="btn-cancel"><i class="bi bi-x-lg"></i> Cancelar</a>
                <button type="submit" class="btn-delete"><i class="bi bi-trash-fill"></i> Sim, Excluir</button>
            </div>
        }
    </div>
</div>
