@model SistemaWebAgendamentoFerriCT.Models.Agendamento

@{
    ViewBag.Title = "Agendamento Confirmado";
    var pagamento = Model.Pagamentos?.FirstOrDefault();
}

<style>
    .confirm-wrapper {
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 16px;
    }

    .confirm-card {
        width: 100%;
        max-width: 520px;
        background: var(--bg-card);
        border: 1px solid rgba(76,175,130,0.25);
        border-radius: var(--radius-lg);
        padding: 48px 44px;
        text-align: center;
        position: relative;
        animation: fadeUp 0.6s ease forwards;
    }

        .confirm-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 40px;
            right: 40px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--success), transparent);
            border-radius: 999px;
        }

    .check-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(76,175,130,0.12);
        border: 2px solid rgba(76,175,130,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        font-size: 2rem;
        color: var(--success);
        animation: popIn 0.5s ease 0.3s both;
    }

    .confirm-title {
        font-family: 'Bebas Neue',sans-serif;
        font-size: 2.4rem;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

        .confirm-title span {
            color: var(--success);
        }

    .confirm-desc {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.7;
        margin-bottom: 24px;
    }

    /* Resumo do agendamento */
    .resumo-box {
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 16px;
        margin-bottom: 24px;
        text-align: left;
    }

    .resumo-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.875rem;
    }

        .resumo-row:last-child {
            border: none;
            padding-bottom: 0;
        }

        .resumo-row i {
            color: var(--accent);
            width: 16px;
            text-align: center;
        }

    .resumo-label {
        color: var(--text-secondary);
        min-width: 110px;
        font-size: 0.78rem;
    }

    .resumo-val {
        font-weight: 600;
    }

    .badge-confirmado {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(76,175,130,0.12);
        border: 1px solid rgba(76,175,130,0.3);
        color: var(--success);
        border-radius: 999px;
        padding: 6px 16px;
        font-size: 0.75rem;
        font-weight: 600;
        margin-bottom: 24px;
    }

    .confirm-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .btn-primary-confirm {
        background: var(--accent);
        color: var(--bg-deep);
        border: none;
        border-radius: var(--radius-sm);
        padding: 14px;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-primary-confirm:hover {
            background: var(--accent-hover);
            color: var(--bg-deep);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px var(--accent-glow);
        }

    .btn-secondary-confirm {
        background: transparent;
        color: var(--text-secondary);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 14px;
        font-weight: 500;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-secondary-confirm:hover {
            color: var(--text-primary);
            border-color: rgba(255,255,255,0.15);
        }

    .info-note {
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
        font-size: 0.78rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

        .info-note strong {
            color: var(--text-primary);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes popIn {
        from {
            opacity: 0;
            transform: scale(0.5);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    /* Header do comprovante — só aparece quando imprime */
    .print-only { display: none; }

    /* ─── PRINT (Bloco 6) ─── Esta tela vira comprovante na impressão */
    @@media print {
        .confirm-wrapper {
            padding: 0 !important;
            min-height: auto !important;
            display: block !important;
        }

        .confirm-card {
            background: #fff !important;
            border: 2px solid #000 !important;
            border-radius: 0 !important;
            max-width: 100% !important;
            padding: 24px !important;
            page-break-inside: avoid;
        }

            .confirm-card::before { display: none !important; }

        .print-only {
            display: block !important;
            text-align: center;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 1px solid #000;
        }

        .print-only-brand {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 22pt;
            letter-spacing: 4px;
            color: #000;
            margin-bottom: 4px;
        }

        .print-only-label {
            font-size: 10pt;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #555;
        }

        .check-circle,
        .confirm-actions,
        .info-note {
            display: none !important;
        }

        .confirm-title { font-size: 18pt !important; color: #000 !important; }
            .confirm-title span { color: #000 !important; }

        .confirm-desc { color: #333 !important; font-size: 10pt; }

        .badge-confirmado {
            background: #fff !important;
            border: 1px solid #000 !important;
            color: #000 !important;
        }

        .resumo-box {
            background: #fff !important;
            border: 1px solid #000 !important;
        }

        .resumo-row {
            border-bottom: 1px solid #ccc !important;
        }

            .resumo-row i,
            .resumo-label,
            .resumo-val { color: #000 !important; }
    }
</style>

<div class="confirm-wrapper">
    <div class="confirm-card">

        <div class="print-only" aria-hidden="true">
            <div class="print-only-brand">FERRI CT</div>
            <div class="print-only-label">Comprovante de Agendamento</div>
        </div>

        <div class="check-circle" aria-hidden="true">
            <i class="bi bi-check-lg"></i>
        </div>

        <div class="confirm-title">AULA <span>CONFIRMADA!</span></div>

        <p class="confirm-desc">
            Seu pagamento foi aprovado e a aula está confirmada.
            Apareça na hora marcada pronto para treinar!
        </p>

        <div class="badge-confirmado">
            <i class="bi bi-check-circle-fill"></i> Agendamento Confirmado
        </div>

        <!-- Resumo do agendamento -->
        <div class="resumo-box">
            <div class="resumo-row">
                <i class="bi bi-calendar3"></i>
                <span class="resumo-label">Data</span>
                <span class="resumo-val">@Model.DataAula.ToString("dd/MM/yyyy") (@Model.DataAula.ToString("dddd", new System.Globalization.CultureInfo("pt-BR")))</span>
            </div>
            <div class="resumo-row">
                <i class="bi bi-clock"></i>
                <span class="resumo-label">Horário</span>
                <span class="resumo-val">
                    @(Model.HorarioTurma != null
                        ? $"{Model.HorarioTurma.HoraInicio:hh\\:mm} - {Model.HorarioTurma.HoraFim:hh\\:mm}"
                        : "—")
                </span>
            </div>
            <div class="resumo-row">
                <i class="bi bi-people"></i>
                <span class="resumo-label">Turma</span>
                <span class="resumo-val">@(Model.HorarioTurma?.Turma?.NomeTurma ?? "—")</span>
            </div>
            <div class="resumo-row">
                <i class="bi bi-tag"></i>
                <span class="resumo-label">Tipo</span>
                <span class="resumo-val">@Model.TipoAula</span>
            </div>
            @if (pagamento != null)
            {
                <div class="resumo-row">
                    <i class="bi bi-credit-card"></i>
                    <span class="resumo-label">Pagamento</span>
                    <span class="resumo-val">@pagamento.FormaPagamento — R$ @pagamento.Valor.ToString("N2")</span>
                </div>
                <div class="resumo-row">
                    <i class="bi bi-hash"></i>
                    <span class="resumo-label">Código</span>
                    <span class="resumo-val" style="font-family:monospace;font-size:0.8rem">@pagamento.CodigoTransacao</span>
                </div>
            }
        </div>

        <div class="confirm-actions">
            <a href="/Cliente/Perfil" class="btn-primary-confirm">
                <i class="bi bi-person-fill" aria-hidden="true"></i> Ver Meu Perfil
            </a>
            <button type="button" class="btn-secondary-confirm" onclick="window.print()">
                <i class="bi bi-printer-fill" aria-hidden="true"></i> Imprimir Comprovante
            </button>
            <a href="/Agendamento/Create" class="btn-secondary-confirm">
                <i class="bi bi-calendar-plus" aria-hidden="true"></i> Fazer Outro Agendamento
            </a>
            <a href="/" class="btn-secondary-confirm">
                <i class="bi bi-house-fill" aria-hidden="true"></i> Voltar ao Início
            </a>
        </div>

        <div class="info-note">
            <strong>Dúvidas?</strong><br>
            Entre em contato pelo WhatsApp <strong>(18) 98808-6628</strong>.
            Acompanhe seus agendamentos pelo seu perfil a qualquer momento.
        </div>

    </div>
</div>
