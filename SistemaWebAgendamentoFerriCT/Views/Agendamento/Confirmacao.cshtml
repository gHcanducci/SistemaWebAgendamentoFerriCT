@{
    ViewBag.Title = "Agendamento Confirmado";
}

<style>
    .confirm-wrapper {
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 16px;
        position: relative;
    }

        .confirm-wrapper::before {
            content: '';
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 600px;
            height: 600px;
            background: radial-gradient(circle, rgba(76,175,130,0.06) 0%, transparent 70%);
            pointer-events: none;
        }

    .confirm-card {
        width: 100%;
        max-width: 480px;
        background: var(--bg-card);
        border: 1px solid rgba(76,175,130,0.25);
        border-radius: var(--radius-lg);
        padding: 52px 44px;
        text-align: center;
        position: relative;
        z-index: 1;
        animation: fadeUp 0.6s ease forwards;
    }

        .confirm-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 40px;
            right: 40px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--success), transparent);
            border-radius: 999px;
        }

    .check-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(76,175,130,0.12);
        border: 2px solid rgba(76,175,130,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 24px;
        font-size: 2rem;
        color: var(--success);
        animation: popIn 0.5s ease 0.3s both;
    }

    .confirm-title {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2.4rem;
        letter-spacing: 1px;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

        .confirm-title span {
            color: var(--success);
        }

    .confirm-desc {
        color: var(--text-secondary);
        font-size: 0.9rem;
        line-height: 1.7;
        margin-bottom: 32px;
        max-width: 360px;
        margin-left: auto;
        margin-right: auto;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--accent-dim);
        border: 1px solid rgba(232,197,71,0.3);
        color: var(--accent);
        border-radius: 999px;
        padding: 8px 20px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-bottom: 32px;
        letter-spacing: 0.5px;
    }

    .confirm-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .btn-primary-confirm {
        background: var(--accent);
        color: var(--bg-deep);
        border: none;
        border-radius: var(--radius-sm);
        padding: 14px;
        font-weight: 700;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-primary-confirm:hover {
            background: #f5d465;
            color: var(--bg-deep);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px var(--accent-glow);
        }

    .btn-secondary-confirm {
        background: transparent;
        color: var(--text-secondary);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 14px;
        font-weight: 500;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

        .btn-secondary-confirm:hover {
            color: var(--text-primary);
            border-color: rgba(255,255,255,0.15);
        }

    .info-note {
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
        font-size: 0.78rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

        .info-note strong {
            color: var(--text-primary);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes popIn {
        from {
            opacity: 0;
            transform: scale(0.5);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }
</style>

<div class="confirm-wrapper">
    <div class="confirm-card">

        <div class="check-circle">
            <i class="bi bi-check-lg"></i>
        </div>

        <div class="confirm-title">AULA <span>AGENDADA!</span></div>

        <p class="confirm-desc">
            Seu agendamento foi registrado com sucesso.
            Aguarde a confirmação e apareça na hora marcada pronto para treinar!
        </p>

        <div class="status-badge">
            <i class="bi bi-clock-fill"></i> Pendente de Confirmação
        </div>

        <div class="confirm-actions">
            <a href="/Cliente/Perfil" class="btn-primary-confirm">
                <i class="bi bi-person-fill"></i> Ver Meu Perfil
            </a>
            <a href="/Agendamento/Create" class="btn-secondary-confirm">
                <i class="bi bi-calendar-plus"></i> Fazer Outro Agendamento
            </a>
            <a href="/" class="btn-secondary-confirm">
                <i class="bi bi-house-fill"></i> Voltar ao Início
            </a>
        </div>

        <div class="info-note">
            <strong>O que acontece agora?</strong><br>
            Nossa equipe irá confirmar sua aula em breve. Você pode acompanhar
            o status pelo seu perfil. Em caso de dúvidas, entre em contato pelo
            WhatsApp <strong>(18) 98808-6628</strong>.
        </div>

    </div>
</div>
