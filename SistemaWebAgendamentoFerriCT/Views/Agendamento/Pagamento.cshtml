@model SistemaWebAgendamentoFerriCT.ViewModels.PagamentoViewModel

@{
    ViewBag.Title = "Pagamento";
}

<style>
    .pag-wrapper {
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 16px;
    }

    .pag-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        max-width: 840px;
        width: 100%;
    }

    @@media (max-width: 768px) {
        .pag-grid { grid-template-columns: 1fr; }
    }

    .resumo-card, .pag-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 32px;
    }

    .resumo-card h4, .pag-card h4 {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .resumo-card h4 i, .pag-card h4 i { color: var(--accent); }

    .resumo-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.875rem;
    }

    .resumo-row:last-of-type { border: none; }
    .resumo-row i { color: var(--accent); width: 16px; }
    .resumo-label { color: var(--text-secondary); min-width: 80px; font-size: 0.78rem; }
    .resumo-val { font-weight: 600; }

    .valor-total {
        margin-top: 20px;
        padding: 16px;
        background: rgba(255,204,0,0.08);
        border: 1px solid rgba(255,204,0,0.2);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .valor-total span { font-size: 0.85rem; color: var(--text-secondary); }
    .valor-total strong {
        font-size: 1.6rem;
        color: var(--accent);
        font-family: 'Bebas Neue', sans-serif;
        letter-spacing: 1px;
    }

    .pag-card .subtitle {
        color: var(--text-secondary);
        font-size: 0.82rem;
        margin-bottom: 24px;
    }

    .metodos-aceitos {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .metodo-chip {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 10px 14px;
        background: rgba(255,255,255,0.03);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        font-size: 0.82rem;
        font-weight: 600;
        flex: 1;
        justify-content: center;
    }

    .metodo-chip .icon { font-size: 1.2rem; }

    .seguranca-info {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin-bottom: 20px;
    }

    .seguranca-info i { color: var(--success); }

    .btn-pagar {
        width: 100%;
        background: var(--accent);
        color: var(--bg-deep);
        border: none;
        border-radius: var(--radius-sm);
        padding: 15px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'DM Sans', sans-serif;
    }

    .btn-pagar:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px var(--accent-glow);
    }

    .btn-pagar:disabled { opacity: 0.6; cursor: wait; transform: none; }

    .cancelar-link {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        color: var(--text-secondary);
        text-decoration: none;
        font-size: 0.82rem;
        margin-top: 16px;
        transition: color 0.2s;
    }

    .cancelar-link:hover { color: var(--danger); }

    .alert-erro {
        background: rgba(255,90,90,0.08);
        border: 1px solid rgba(255,90,90,0.3);
        color: #ff7a7a;
        padding: 12px 14px;
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        margin-bottom: 16px;
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(24px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .fade-up { animation: fadeUp 0.5s ease forwards; }
</style>

<div class="pag-wrapper">
    <div class="pag-grid">

        <!-- Resumo -->
        <div class="resumo-card fade-up">
            <h4><i class="bi bi-receipt"></i> Resumo do Agendamento</h4>

            <div class="resumo-row">
                <i class="bi bi-calendar3"></i>
                <span class="resumo-label">Data</span>
                <span class="resumo-val">@Model.DataAula.ToString("dd/MM/yyyy")</span>
            </div>
            <div class="resumo-row">
                <i class="bi bi-clock"></i>
                <span class="resumo-label">Horário</span>
                <span class="resumo-val">@Model.HorarioFormatado</span>
            </div>
            <div class="resumo-row">
                <i class="bi bi-tag"></i>
                <span class="resumo-label">Tipo</span>
                <span class="resumo-val">@Model.TipoAula</span>
            </div>

            <div class="valor-total">
                <span>Total a pagar</span>
                <strong>R$ @Model.Valor.ToString("N2")</strong>
            </div>

            <div style="margin-top:20px;font-size:0.78rem;color:var(--text-secondary);line-height:1.6">
                <i class="bi bi-info-circle me-1" style="color:var(--accent)"></i>
                O agendamento é <strong style="color:var(--text-primary)">confirmado automaticamente</strong>
                após a aprovação do pagamento.
            </div>
        </div>

        <!-- Pagamento -->
        <div class="pag-card" style="animation:fadeUp 0.5s ease 0.1s both">
            <h4><i class="bi bi-credit-card-2-front"></i> Pagamento</h4>
            <p class="subtitle">Escolha a forma de pagamento para confirmar seu agendamento.</p>

            @if (TempData["Erro"] != null)
            {
                <div class="alert-erro">
                    <i class="bi bi-exclamation-circle"></i> @TempData["Erro"]
                </div>
            }

            <div class="seguranca-info">
                <i class="bi bi-info-circle-fill"></i>
                Modo demonstração: o pagamento é confirmado automaticamente para fins de apresentação.
            </div>

            @using (Html.BeginForm("IniciarPagamento", "Agendamento", FormMethod.Post, new { id = "form-pix", @class = "form-pgto" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="agendamentoId" value="@Model.AgendamentoId" />
                <input type="hidden" name="formaPagamento" value="PIX" />

                <button type="submit" class="btn-pagar" data-btn-pgto>
                    <span class="icon" style="font-size:1.2rem">⚡</span>
                    Pagar com PIX — R$ @Model.Valor.ToString("N2")
                </button>
            }

            <div style="height:12px"></div>

            @using (Html.BeginForm("IniciarPagamento", "Agendamento", FormMethod.Post, new { id = "form-debito", @class = "form-pgto" }))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="agendamentoId" value="@Model.AgendamentoId" />
                <input type="hidden" name="formaPagamento" value="Debito" />

                <button type="submit" class="btn-pagar" data-btn-pgto
                        style="background:transparent;color:var(--accent);border:1px solid var(--accent)">
                    <i class="bi bi-credit-card-2-front"></i>
                    Pagar com Débito — R$ @Model.Valor.ToString("N2")
                </button>
            }

            <a href="/Cliente/Perfil" class="cancelar-link">
                <i class="bi bi-x-circle"></i> Voltar ao perfil
            </a>
        </div>

    </div>
</div>

<script>
    // Evita duplo clique e desabilita o outro botão enquanto processa
    document.querySelectorAll('.form-pgto').forEach(function (form) {
        form.addEventListener('submit', function () {
            document.querySelectorAll('[data-btn-pgto]').forEach(function (b) {
                b.disabled = true;
            });
            var btn = form.querySelector('[data-btn-pgto]');
            btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Confirmando...';
        });
    });
</script>
