@model SistemaWebAgendamentoFerriCT.Models.Cliente

@{
    ViewBag.Title = "Meu Perfil";
}

<style>
    .perfil-wrapper {
        min-height: calc(100vh - 64px);
        padding: 48px 24px;
    }

    .perfil-grid {
        display: grid;
        grid-template-columns: 260px 1fr;
        gap: 20px;
        max-width: 960px;
        margin: 0 auto;
    }

    @@media (max-width: 768px) {
        .perfil-grid {
            grid-template-columns: 1fr;
        }
    }

    /* ─── Card lateral ─── */
    .perfil-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 28px 20px;
        text-align: center;
        position: relative;
        height: fit-content;
    }

        .perfil-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 30px;
            right: 30px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            border-radius: 999px;
        }

    .perfil-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: var(--accent-dim);
        border: 2px solid rgba(255,204,0,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Bebas Neue', sans-serif;
        font-size: 1.8rem;
        color: var(--accent);
        margin: 0 auto 14px;
    }

    .perfil-nome {
        font-weight: 700;
        font-size: 1rem;
        margin-bottom: 4px;
    }

    .perfil-since {
        font-size: 0.72rem;
        color: var(--text-secondary);
        margin-bottom: 16px;
    }

    .perfil-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        background: rgba(76,175,130,0.12);
        border: 1px solid rgba(76,175,130,0.25);
        color: var(--success);
        border-radius: 999px;
        padding: 4px 12px;
        font-size: 0.72rem;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .perfil-actions {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

        .perfil-actions a {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px;
            border-radius: var(--radius-sm);
            font-size: 0.83rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
        }

    .btn-agendar {
        background: var(--accent);
        color: var(--bg-deep);
        border: none;
    }

        .btn-agendar:hover {
            background: var(--accent-hover);
            color: var(--bg-deep);
            transform: translateY(-1px);
            box-shadow: 0 6px 20px var(--accent-glow);
        }

    .btn-editar-perfil {
        background: var(--accent-dim);
        border: 1px solid rgba(255,204,0,0.25);
        color: var(--accent);
    }

        .btn-editar-perfil:hover {
            background: rgba(255,204,0,0.2);
            color: var(--accent);
        }

    .btn-excluir-perfil {
        background: rgba(224,80,80,0.08);
        border: 1px solid rgba(224,80,80,0.2);
        color: var(--danger);
    }

        .btn-excluir-perfil:hover {
            background: rgba(224,80,80,0.15);
            color: var(--danger);
        }

    /* ─── Cards de info ─── */
    .info-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        margin-bottom: 16px;
    }

        .info-card:last-child {
            margin-bottom: 0;
        }

    .info-header {
        padding: 14px 20px;
        border-bottom: 1px solid var(--border);
        font-weight: 700;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .info-header i {
            color: var(--accent);
        }

    .info-body {
        padding: 4px 20px 16px;
    }

    .info-row {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
    }

        .info-row:last-child {
            border: none;
        }

    .info-icon {
        width: 32px;
        height: 32px;
        flex-shrink: 0;
        background: rgba(255,255,255,0.04);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        font-size: 0.875rem;
    }

    .info-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-secondary);
        font-weight: 700;
        margin-bottom: 2px;
    }

    .info-value {
        font-size: 0.875rem;
        font-weight: 600;
    }

    /* ─── Tabela de agendamentos ─── */
    .ag-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 3px;
    }

        .ag-table thead th {
            color: var(--text-secondary);
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            padding: 8px 12px;
            font-weight: 700;
            border: none;
        }

        .ag-table tbody tr {
            background: rgba(255,255,255,0.02);
            transition: background 0.2s;
        }

            .ag-table tbody tr:hover {
                background: rgba(255,204,0,0.04);
            }

        .ag-table tbody td {
            padding: 11px 12px;
            border: none;
            vertical-align: middle;
            font-size: 0.83rem;
        }

            .ag-table tbody td:first-child {
                border-radius: var(--radius-sm) 0 0 var(--radius-sm);
            }

            .ag-table tbody td:last-child {
                border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            }

    /* Botão "Efetuar Pagamento" na linha do agendamento */
    .btn-pagar-ag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: var(--accent);
        color: var(--bg-deep);
        border: none;
        border-radius: var(--radius-sm);
        padding: 7px 12px;
        font-size: 0.75rem;
        font-weight: 700;
        text-decoration: none;
        white-space: nowrap;
        transition: all 0.2s;
    }

        .btn-pagar-ag:hover {
            background: var(--accent-hover);
            color: var(--bg-deep);
            transform: translateY(-1px);
            box-shadow: 0 4px 14px var(--accent-glow);
        }

    /* Wrapper que junta o botão de pagar com o botão de cancelar */
    .acoes-ag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-cancelar-ag {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 30px;
        height: 30px;
        background: rgba(224,80,80,0.08);
        border: 1px solid rgba(224,80,80,0.2);
        color: var(--danger);
        border-radius: var(--radius-sm);
        font-size: 0.85rem;
        text-decoration: none;
        transition: all 0.2s;
        flex-shrink: 0;
    }

        .btn-cancelar-ag:hover {
            background: rgba(224,80,80,0.18);
            color: var(--danger);
        }

    .acao-vazia {
        color: var(--text-secondary);
        font-size: 0.8rem;
        opacity: 0.5;
    }

    /* Badges de status */
    .badge-status {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 3px 10px;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 600;
        white-space: nowrap;
    }

        .badge-status::before {
            content: '';
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: currentColor;
        }

    .badge-confirmado {
        color: var(--success);
        background: rgba(76,175,130,0.12);
    }

    .badge-pendente {
        color: var(--accent);
        background: var(--accent-dim);
    }

    .badge-cancelado {
        color: var(--danger);
        background: rgba(224,80,80,0.12);
    }

    /* Turma pill */
    .turma-pill {
        display: inline-block;
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 2px 8px;
        font-size: 0.72rem;
        color: var(--text-secondary);
        margin-left: 4px;
    }

    .empty-state {
        text-align: center;
        padding: 40px;
        color: var(--text-secondary);
        font-size: 0.875rem;
    }

        .empty-state i {
            font-size: 2rem;
            opacity: 0.2;
            display: block;
            margin-bottom: 10px;
        }

    /* Toast */
    .toast-msg {
        position: fixed;
        top: 80px;
        right: 24px;
        z-index: 9999;
        padding: 12px 20px;
        border-radius: 10px;
        font-size: 0.875rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        animation: fadeUp 0.4s ease forwards;
    }

    .toast-sucesso {
        background: rgba(76,175,130,0.15);
        border: 1px solid rgba(76,175,130,0.4);
        color: var(--success);
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ─── Mobile: tabela vira cards (≤768px) ─── */
    @@media (max-width: 768px) {
        .perfil-wrapper { padding: 24px 14px; }

        .ag-table thead { display: none; }

        .ag-table,
        .ag-table tbody,
        .ag-table tbody tr,
        .ag-table tbody td {
            display: block;
            width: 100%;
        }

        .ag-table { border-spacing: 0; }

        .ag-table tbody tr {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            padding: 12px 14px;
            margin-bottom: 10px;
        }

            .ag-table tbody tr:hover {
                background: rgba(255,255,255,0.03);
            }

        .ag-table tbody td {
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            font-size: 0.82rem;
        }

            .ag-table tbody td:last-child {
                border-bottom: none;
            }

            .ag-table tbody td::before {
                content: attr(data-label);
                font-size: 0.72rem;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: var(--text-secondary);
                font-weight: 700;
                flex-shrink: 0;
            }

            /* Data vira header do card (sem label, data em destaque) */
            .ag-table tbody td[data-label="Data"] {
                display: block;
                padding: 0 0 10px;
                margin-bottom: 6px;
                border-bottom: 1px solid var(--border);
            }

                .ag-table tbody td[data-label="Data"]::before {
                    display: none;
                }

                .ag-table tbody td[data-label="Data"] span:first-child {
                    color: var(--accent);
                    font-size: 1rem;
                }

            /* Ações vira rodapé centralizado */
            .ag-table tbody td[data-label="Ações"] {
                justify-content: center;
                padding-top: 12px;
                margin-top: 4px;
                border-top: 1px solid var(--border);
                border-bottom: none;
            }

                .ag-table tbody td[data-label="Ações"]::before {
                    display: none;
                }

            .ag-table tbody td[data-label="Ações"] .acoes-ag {
                width: 100%;
            }

            .ag-table tbody td[data-label="Ações"] .btn-pagar-ag {
                flex: 1;
                justify-content: center;
                padding: 10px;
                font-size: 0.82rem;
            }

            .ag-table tbody td[data-label="Ações"] .btn-cancelar-ag {
                width: 38px;
                height: 38px;
                font-size: 1rem;
            }

            .ag-table tbody td[data-label="Ações"] .acao-vazia {
                display: none;
            }
    }
</style>

@if (TempData["Sucesso"] != null)
{
    <div class="toast-msg toast-sucesso" role="status" aria-live="polite">
        <i class="bi bi-check-circle-fill" aria-hidden="true"></i> @TempData["Sucesso"]
    </div>
}

<div class="perfil-wrapper">
    <div class="perfil-grid">

        <!-- ─── Coluna esquerda ─── -->
        <div>
            <div class="perfil-card fade-up">
                @{
                    var initials = string.Join("", (Model.Nome ?? "?").Split(' ')
                        .Take(2).Select(w => w.Length > 0 ? w[0].ToString().ToUpper() : ""));
                }
                <div class="perfil-avatar">@initials</div>
                <div class="perfil-nome">@Model.Nome</div>
                <div class="perfil-since">Aluno desde @Model.DataCadastro.ToString("MM/yyyy")</div>
                <div class="perfil-badge"><i class="bi bi-check-circle-fill"></i> Ativo</div>

                <div class="perfil-actions">
                    <a href="/Agendamento/Create" class="btn-agendar">
                        <i class="bi bi-calendar-check-fill"></i> Agendar Aula
                    </a>
                    <a href="/Cliente/Editar" class="btn-editar-perfil">
                        <i class="bi bi-pencil-fill"></i> Editar Dados
                    </a>
                    <a href="/Cliente/Excluir" class="btn-excluir-perfil">
                        <i class="bi bi-trash-fill"></i> Excluir Conta
                    </a>
                </div>
            </div>
        </div>

        <!-- ─── Coluna direita ─── -->
        <div>

            <!-- Dados pessoais -->
            <div class="info-card fade-up delay-1">
                <div class="info-header"><i class="bi bi-person-lines-fill"></i> Dados Pessoais</div>
                <div class="info-body">
                    <div class="info-row">
                        <div class="info-icon"><i class="bi bi-person"></i></div>
                        <div><div class="info-label">Nome Completo</div><div class="info-value">@Model.Nome</div></div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="bi bi-envelope"></i></div>
                        <div><div class="info-label">E-mail</div><div class="info-value">@Model.Email</div></div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="bi bi-telephone"></i></div>
                        <div><div class="info-label">Telefone</div><div class="info-value">@Model.Telefone</div></div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="bi bi-person-vcard"></i></div>
                        <div><div class="info-label">CPF</div><div class="info-value">@Model.CPF</div></div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="bi bi-calendar3"></i></div>
                        <div><div class="info-label">Cadastrado em</div><div class="info-value">@Model.DataCadastro.ToString("dd/MM/yyyy")</div></div>
                    </div>
                </div>
            </div>

            <!-- Meus Agendamentos -->
            <div class="info-card fade-up delay-2">
                <div class="info-header">
                    <i class="bi bi-calendar-check-fill"></i> Meus Agendamentos
                    @if (Model.Agendamentos != null && Model.Agendamentos.Any())
                    {
                        <span style="margin-left:auto;font-size:0.72rem;color:var(--text-secondary);font-weight:400">
                            @Model.Agendamentos.Count() registro(s)
                        </span>
                    }
                </div>

                <div style="padding:0">
                    @if (Model.Agendamentos != null && Model.Agendamentos.Any())
                    {
                        <table class="ag-table" aria-label="Meus agendamentos">
                            <thead>
                                <tr>
                                    <th>Data</th>
                                    <th>Horário</th>
                                    <th>Tipo</th>
                                    <th>Status</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ag in Model.Agendamentos.OrderByDescending(a => a.DataAula))
                                {
                                    string sc;
                                    if (ag.Status == "Confirmado") { sc = "badge-confirmado"; }
                                    else if (ag.Status == "Cancelado") { sc = "badge-cancelado"; }
                                    else { sc = "badge-pendente"; }

                                    string statusLabel;
                                    if (ag.Status == "PendentePagamento") { statusLabel = "Pend. Pagamento"; }
                                    else { statusLabel = ag.Status; }

                                    string horario = ag.HorarioTurma != null
                                                        ? ag.HorarioTurma.HoraInicio.ToString(@"hh\:mm") + " - " + ag.HorarioTurma.HoraFim.ToString(@"hh\:mm")
                                                        : "—";

                                    string turma = ag.HorarioTurma?.Turma?.NomeTurma ?? "";

                                    <tr>
                                        <td data-label="Data">
                                            <span style="font-weight:600">@ag.DataAula.ToString("dd/MM/yyyy")</span>
                                            <br>
                                            <span style="font-size:0.72rem;color:var(--text-secondary)">
                                                @ag.DataAula.ToString("dddd", new System.Globalization.CultureInfo("pt-BR"))
                                            </span>
                                        </td>
                                        <td data-label="Horário">
                                            <span style="font-weight:600">@horario</span>
                                            @if (!string.IsNullOrEmpty(turma))
                                            {
                                                <span class="turma-pill">@turma</span>
                                            }
                                        </td>
                                        <td data-label="Tipo" style="color:var(--text-secondary)">@ag.TipoAula</td>
                                        <td data-label="Status"><span class="badge-status @sc">@statusLabel</span></td>
                                        <td data-label="Ações">
                                            @if (ag.Status == "PendentePagamento")
                                            {
                                                <div class="acoes-ag">
                                                    <a href="@Url.Action("Pagamento", "Agendamento", new { id = ag.AgendamentoId })" class="btn-pagar-ag">
                                                        <i class="bi bi-credit-card-fill"></i> Efetuar Pagamento
                                                    </a>
                                                    <a href="@Url.Action("Cancelar", "Agendamento", new { id = ag.AgendamentoId })" class="btn-cancelar-ag" title="Cancelar agendamento"
                                                       aria-label="Cancelar agendamento de @ag.DataAula.ToString("dd/MM/yyyy")">
                                                        <i class="bi bi-x-lg" aria-hidden="true"></i>
                                                    </a>
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="acao-vazia">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="bi bi-calendar-x"></i>
                            Nenhum agendamento ainda.
                            <br>
                            <a href="/Agendamento/Create" style="color:var(--accent);font-weight:600;text-decoration:none;margin-top:8px;display:inline-block">
                                Agendar agora →
                            </a>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    setTimeout(() => {
        document.querySelectorAll('.toast-msg').forEach(t => {
            t.style.opacity = '0';
            t.style.transition = 'opacity 0.5s';
            setTimeout(() => t.remove(), 500);
        });
    }, 4000);
</script>
