@model SistemaWebAgendamentoFerriCT.Models.Cliente

@{
    ViewBag.Title = "Editar Perfil";
}

<style>
    .edit-wrapper {
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 16px;
    }

    .edit-card {
        width: 100%;
        max-width: 520px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        animation: fadeUp 0.5s ease forwards;
    }

        .edit-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 40px;
            right: 40px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
        }

    .edit-header {
        padding: 24px 28px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .edit-header-icon {
        width: 40px;
        height: 40px;
        background: var(--accent-dim);
        border: 1px solid rgba(255,204,0,0.2);
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        font-size: 1.1rem;
    }

    .edit-header-title {
        font-weight: 700;
        font-size: 1rem;
    }

    .edit-header-sub {
        font-size: 0.78rem;
        color: var(--text-secondary);
    }

    .edit-body {
        padding: 28px;
    }

    .field-block {
        margin-bottom: 18px;
    }

    .form-label {
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        font-weight: 700;
        color: var(--text-secondary);
        margin-bottom: 6px;
        display: block;
    }

    .input-icon {
        position: relative;
    }

        .input-icon .fi {
            position: absolute;
            left: 13px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            pointer-events: none;
        }

        .input-icon .form-control {
            padding-left: 38px !important;
        }

    .cpf-note {
        font-size: 0.72rem;
        color: var(--text-secondary);
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .cpf-note i {
            color: var(--accent);
        }

    .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 24px;
    }

    .btn-save {
        flex: 1;
        background: var(--accent);
        color: var(--bg-deep);
        border: none;
        border-radius: var(--radius-sm);
        padding: 13px;
        font-weight: 700;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'DM Sans', sans-serif;
    }

        .btn-save:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 24px var(--accent-glow);
        }

    .btn-cancel {
        background: transparent;
        color: var(--text-secondary);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 13px 20px;
        font-weight: 600;
        font-size: 0.875rem;
        cursor: pointer;
        transition: all 0.2s;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-cancel:hover {
            color: var(--text-primary);
            border-color: rgba(255,255,255,0.15);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(24px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="edit-wrapper">
    <div class="edit-card" style="position:relative">
        <div class="edit-header">
            <div class="edit-header-icon"><i class="bi bi-pencil-fill"></i></div>
            <div>
                <div class="edit-header-title">Editar Meus Dados</div>
                <div class="edit-header-sub">Atualize suas informações de cadastro</div>
            </div>
        </div>
        <div class="edit-body">

            @using (Html.BeginForm("Editar", "Cliente", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.ClienteId)
                @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3", style = "font-size:0.82rem" })

                <div class="field-block">
                    <label class="form-label">Nome Completo</label>
                    <div class="input-icon">
                        <i class="bi bi-person fi"></i>
                        @Html.TextBoxFor(m => m.Nome, new { @class = "form-control", placeholder = "Seu nome completo" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "text-danger", style = "font-size:0.75rem" })
                </div>

                <div class="field-block">
                    <label class="form-label">E-mail</label>
                    <div class="input-icon">
                        <i class="bi bi-envelope fi"></i>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "seu@email.com" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger", style = "font-size:0.75rem" })
                </div>

                <div class="field-block">
                    <label class="form-label">Telefone</label>
                    <div class="input-icon">
                        <i class="bi bi-telephone fi"></i>
                        @Html.TextBoxFor(m => m.Telefone, new { @class = "form-control", placeholder = "(00) 00000-0000", id = "telField" })
                    </div>
                    @Html.ValidationMessageFor(m => m.Telefone, "", new { @class = "text-danger", style = "font-size:0.75rem" })
                </div>

                <div class="field-block">
                    <label class="form-label">CPF</label>
                    <div class="input-icon">
                        <i class="bi bi-person-vcard fi"></i>
                        @Html.TextBoxFor(m => m.CPF, new { @class = "form-control", disabled = "disabled", style = "opacity:0.5;cursor:not-allowed" })
                    </div>
                    <div class="cpf-note"><i class="bi bi-lock-fill"></i> O CPF não pode ser alterado.</div>
                </div>

                <div class="form-actions">
                    <a href="/Cliente/Perfil" class="btn-cancel"><i class="bi bi-x-lg"></i> Cancelar</a>
                    <button type="submit" class="btn-save"><i class="bi bi-check-lg"></i> Salvar Alterações</button>
                </div>
            }
        </div>
    </div>
</div>

<script>const tel = document.getElementById('telField');
    if (tel) {
        tel.addEventListener('input', function () {
            let v = this.value.replace(/\D/g, '').substring(0, 11);
            if (v.length > 6) v = v.replace(/^(\d{2})(\d{5})(\d{0,4})/, '($1) $2-$3');
            else if (v.length > 2) v = v.replace(/^(\d{2})(\d{0,5})/, '($1) $2');
            this.value = v;
        });
    }</script>
