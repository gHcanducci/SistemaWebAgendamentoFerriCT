@{
    ViewBag.Title = "Acessar Conta";
}

<style>
    .auth-wrapper {
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        position: relative;
    }

        /* Background glow spots */
        .auth-wrapper::before {
            content: '';
            position: fixed;
            top: 20%;
            left: 50%;
            transform: translateX(-50%);
            width: 600px;
            height: 400px;
            background: radial-gradient(ellipse, rgba(232,197,71,0.05) 0%, transparent 70%);
            pointer-events: none;
        }

    .auth-card {
        width: 100%;
        max-width: 420px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 48px 40px;
        position: relative;
        z-index: 1;
        animation: fadeUp 0.6s ease forwards;
    }

        /* Top accent line */
        .auth-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 40px;
            right: 40px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            border-radius: 999px;
        }

    .auth-logo {
        text-align: center;
        margin-bottom: 32px;
    }

    .auth-logo-mark {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 3rem;
        letter-spacing: 4px;
        color: var(--accent);
        display: block;
        line-height: 1;
    }

    .auth-logo-sub {
        font-size: 0.7rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--text-secondary);
        margin-top: 4px;
    }

    .auth-title {
        font-size: 1.5rem;
        font-weight: 700;
        margin-bottom: 4px;
        text-align: center;
    }

    .auth-subtitle {
        color: var(--text-secondary);
        font-size: 0.875rem;
        text-align: center;
        margin-bottom: 32px;
    }

    .input-group-icon {
        position: relative;
        margin-bottom: 16px;
    }

        .input-group-icon .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            font-size: 1rem;
            z-index: 2;
        }

        .input-group-icon .form-control {
            padding-left: 44px !important;
        }

    .btn-login {
        width: 100%;
        background: var(--accent);
        color: var(--bg-deep);
        border: none;
        border-radius: var(--radius-sm);
        padding: 14px;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.5px;
        transition: all 0.3s;
        margin-top: 8px;
        cursor: pointer;
    }

        .btn-login:hover {
            background: #f5d465;
            transform: translateY(-2px);
            box-shadow: 0 8px 28px var(--accent-glow);
        }

        .btn-login:active {
            transform: translateY(0);
        }

    .auth-divider {
        display: flex;
        align-items: center;
        gap: 16px;
        margin: 24px 0;
    }

        .auth-divider span {
            color: var(--text-secondary);
            font-size: 0.8rem;
            white-space: nowrap;
        }

        .auth-divider::before, .auth-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

    .auth-footer-link {
        text-align: center;
        font-size: 0.875rem;
        color: var(--text-secondary);
    }

        .auth-footer-link a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
            transition: opacity 0.2s;
        }

            .auth-footer-link a:hover {
                opacity: 0.8;
                text-decoration: underline;
            }

    .alert-error {
        background: rgba(224,80,80,0.1);
        border: 1px solid rgba(224,80,80,0.3);
        color: #ff8a8a;
        border-radius: var(--radius-sm);
        padding: 12px 16px;
        font-size: 0.85rem;
        margin-bottom: 20px;
        display: none;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-logo">
            <span class="auth-logo-mark">FERRI CT</span>
            <div class="auth-logo-sub">Centro de Treinamento</div>
        </div>

        <div class="auth-title">Bem-vindo de volta</div>
        <div class="auth-subtitle">Acesse sua conta para gerenciar seus agendamentos</div>

        <div class="alert-error" id="errorAlert">
            <i class="bi bi-exclamation-triangle me-2"></i>
            E-mail ou CPF inválidos. Verifique e tente novamente.
        </div>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            <div class="input-group-icon">
                <i class="bi bi-envelope input-icon"></i>
                <input name="email" type="email" class="form-control" placeholder="Seu e-mail" autocomplete="email" />
            </div>

            <div class="input-group-icon">
                <i class="bi bi-person-vcard input-icon"></i>
                <input name="cpf" class="form-control" placeholder="Seu CPF" maxlength="14" id="cpfInput" />
            </div>

            <button type="submit" class="btn-login">
                Entrar <i class="bi bi-arrow-right ms-2"></i>
            </button>
        }

        <div class="auth-divider"><span>ou</span></div>

        <div class="auth-footer-link">
            Ainda não tem conta?
            <a href="/Cliente/Create">Criar conta grátis</a>
        </div>

        <div class="auth-footer-link mt-2">
            <a href="/" style="color:var(--text-secondary);font-weight:400;">
                <i class="bi bi-arrow-left me-1"></i>Voltar ao início
            </a>
        </div>

    </div>
</div>

<script>
    // CPF mask
    const cpf = document.getElementById('cpfInput');
    if (cpf) {
        cpf.addEventListener('input', function () {
            let v = this.value.replace(/\D/g, '').substring(0, 11);
            if (v.length > 9) v = v.replace(/^(\d{3})(\d{3})(\d{3})(\d{0,2})/, '$1.$2.$3-$4');
            else if (v.length > 6) v = v.replace(/^(\d{3})(\d{3})(\d{0,3})/, '$1.$2.$3');
            else if (v.length > 3) v = v.replace(/^(\d{3})(\d{0,3})/, '$1.$2');
            this.value = v;
        });
    }
</script>
