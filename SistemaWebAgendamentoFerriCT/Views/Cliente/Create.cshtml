@model SistemaWebAgendamentoFerriCT.Models.Cliente

@{
    ViewBag.Title = "Criar Conta";
}

<style>
    .auth-wrapper {
        min-height: calc(100vh - 64px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 40px 16px;
        position: relative;
    }

        .auth-wrapper::before {
            content: '';
            position: fixed;
            top: 30%;
            right: 10%;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(255,204,0,0.05) 0%, transparent 70%);
            pointer-events: none;
        }

    .register-card {
        width: 100%;
        max-width: 500px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 48px 44px;
        position: relative;
        z-index: 1;
        animation: fadeUp 0.6s ease forwards;
    }

        .register-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 40px;
            right: 40px;
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent), transparent);
            border-radius: 999px;
        }

    .auth-logo {
        text-align: center;
        margin-bottom: 32px;
    }

    .auth-logo-mark {
        font-family: 'Bebas Neue', sans-serif;
        font-size: 2.8rem;
        letter-spacing: 4px;
        color: var(--accent);
        display: block;
        line-height: 1;
    }

    .auth-logo-sub {
        font-size: 0.7rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--text-secondary);
        margin-top: 4px;
    }

    .step-indicator {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-bottom: 28px;
    }

    .step-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--border);
        transition: all 0.3s;
    }

        .step-dot.active {
            background: var(--accent);
            width: 24px;
            border-radius: 4px;
        }

    .field-group {
        margin-bottom: 18px;
    }

        .field-group .form-label {
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            margin-bottom: 6px;
            display: block;
        }

    .input-with-icon {
        position: relative;
    }

        .input-with-icon .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-secondary);
            font-size: 1rem;
            pointer-events: none;
        }

        .input-with-icon .form-control {
            padding-left: 42px !important;
        }

    .input-valid .form-control {
        border-color: var(--success) !important;
    }

    .input-invalid .form-control {
        border-color: var(--danger) !important;
    }

    .field-hint {
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin-top: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .btn-register {
        width: 100%;
        background: var(--accent);
        color: var(--bg-deep);
        border: none;
        border-radius: var(--radius-sm);
        padding: 14px;
        font-weight: 700;
        font-size: 0.95rem;
        letter-spacing: 0.5px;
        transition: all 0.3s;
        margin-top: 8px;
        cursor: pointer;
    }

        .btn-register:hover {
            background: var(--accent-hover);
            transform: translateY(-2px);
            box-shadow: 0 8px 28px var(--accent-glow);
        }

    .auth-footer-link {
        text-align: center;
        font-size: 0.875rem;
        color: var(--text-secondary);
        margin-top: 24px;
    }

        .auth-footer-link a {
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
        }

            .auth-footer-link a:hover {
                text-decoration: underline;
            }

    .terms-text {
        font-size: 0.75rem;
        color: var(--text-secondary);
        text-align: center;
        margin-top: 16px;
        line-height: 1.5;
    }

        .terms-text a {
            color: var(--accent);
            text-decoration: none;
        }

    .validation-summary-errors ul {
        list-style: none;
        padding: 0;
        margin: 0;
        background: rgba(224,80,80,0.1);
        border: 1px solid rgba(224,80,80,0.3);
        border-radius: var(--radius-sm);
        padding: 12px 16px;
        margin-bottom: 20px;
        font-size: 0.85rem;
        color: #ff8a8a;
    }
</style>

<div class="auth-wrapper">
    <div class="register-card">

        <div class="auth-logo">
            <span class="auth-logo-mark">FERRI CT</span>
            <div class="auth-logo-sub">Centro de Treinamento</div>
        </div>

        <div class="step-indicator">
            <div class="step-dot active"></div>
            <div class="step-dot active"></div>
            <div class="step-dot"></div>
        </div>

        <h2 style="font-size:1.4rem;font-weight:700;text-align:center;margin-bottom:4px;">Crie sua conta</h2>
        <p style="color:var(--text-secondary);font-size:0.875rem;text-align:center;margin-bottom:28px;">
            Comece sua jornada no Ferri CT hoje mesmo
        </p>

        @using (Html.BeginForm())
        {
            @Html.AntiForgeryToken()
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="field-group">
                <label class="form-label">Nome Completo</label>
                <div class="input-with-icon">
                    <i class="bi bi-person field-icon"></i>
                    @Html.TextBoxFor(m => m.Nome, new
                    {
                        @class = "form-control",
                        placeholder = "Seu nome completo",
                        autocomplete = "name"
                    })
                </div>
                @Html.ValidationMessageFor(m => m.Nome, "", new { @class = "field-hint text-danger" })
            </div>

            <div class="field-group">
                <label class="form-label">CPF</label>
                <div class="input-with-icon">
                    <i class="bi bi-person-vcard field-icon"></i>
                    @Html.TextBoxFor(m => m.CPF, new
                    {
                        @class = "form-control",
                        placeholder = "000.000.000-00",
                        id = "cpfField",
                        maxlength = "14"
                    })
                </div>
                @Html.ValidationMessageFor(m => m.CPF, "", new { @class = "field-hint text-danger" })
            </div>

            <div class="field-group">
                <label class="form-label">Telefone / WhatsApp</label>
                <div class="input-with-icon">
                    <i class="bi bi-whatsapp field-icon"></i>
                    @Html.TextBoxFor(m => m.Telefone, new
                    {
                        @class = "form-control",
                        placeholder = "(00) 00000-0000",
                        id = "telField",
                        maxlength = "15"
                    })
                </div>
                @Html.ValidationMessageFor(m => m.Telefone, "", new { @class = "field-hint text-danger" })
            </div>

            <div class="field-group">
                <label class="form-label">E-mail</label>
                <div class="input-with-icon">
                    <i class="bi bi-envelope field-icon"></i>
                    @Html.TextBoxFor(m => m.Email, new
                    {
                        @class = "form-control",
                        placeholder = "seu@email.com",
                        autocomplete = "email"
                    })
                </div>
                @Html.ValidationMessageFor(m => m.Email, "", new { @class = "field-hint text-danger" })
            </div>

            <button type="submit" class="btn-register">
                Criar Conta <i class="bi bi-arrow-right ms-2"></i>
            </button>
        }

        <div class="terms-text">
            Ao criar sua conta, você concorda com nossos
            <a href="#">Termos de Uso</a> e <a href="#">Política de Privacidade</a>.
        </div>

        <div class="auth-footer-link">
            Já tem uma conta? <a href="/Cliente/Login">Entrar</a>
        </div>
        <div class="auth-footer-link mt-1">
            <a href="/" style="color:var(--text-secondary);font-weight:400;font-size:0.8rem">
                <i class="bi bi-arrow-left me-1"></i>Voltar ao início
            </a>
        </div>

    </div>
</div>

<script>
    // CPF mask
    const cpf = document.getElementById('cpfField');
    if (cpf) {
        cpf.addEventListener('input', function () {
            let v = this.value.replace(/\D/g, '').substring(0, 11);
            if (v.length > 9) v = v.replace(/^(\d{3})(\d{3})(\d{3})(\d{0,2})/, '$1.$2.$3-$4');
            else if (v.length > 6) v = v.replace(/^(\d{3})(\d{3})(\d{0,3})/, '$1.$2.$3');
            else if (v.length > 3) v = v.replace(/^(\d{3})(\d{0,3})/, '$1.$2');
            this.value = v;
        });
    }
    // Phone mask
    const tel = document.getElementById('telField');
    if (tel) {
        tel.addEventListener('input', function () {
            let v = this.value.replace(/\D/g, '').substring(0, 11);
            if (v.length > 6) v = v.replace(/^(\d{2})(\d{5})(\d{0,4})/, '($1) $2-$3');
            else if (v.length > 2) v = v.replace(/^(\d{2})(\d{0,5})/, '($1) $2');
            this.value = v;
        });
    }
</script>
