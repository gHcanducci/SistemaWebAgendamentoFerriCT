@{
    ViewBag.Title = "Contato";
}

<style>
    .contact-section { padding: 80px 0 60px; }

    .section-label { font-size:0.72rem; text-transform:uppercase; letter-spacing:3px; color:var(--accent); font-weight:700; margin-bottom:12px; }
    .section-title { font-family:'Bebas Neue',sans-serif; font-size:clamp(36px,5vw,64px); line-height:1; margin-bottom:20px; }

    .contact-grid { display:grid; grid-template-columns:1fr 1fr; gap:32px; }
    media (max-width:768px) { .contact-grid { grid-template-columns:1fr; } }

    /* Info cards */
    .info-item {
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: var(--radius-md); padding: 24px;
        display: flex; gap: 16px; align-items: flex-start;
        transition: all 0.3s; margin-bottom: 12px;
    }
    .info-item:hover { border-color: rgba(232,197,71,0.2); transform: translateX(6px); }
    .info-icon {
        width: 44px; height: 44px; flex-shrink: 0;
        background: var(--accent-dim); border: 1px solid rgba(232,197,71,0.2);
        border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        color: var(--accent); font-size: 1.2rem;
    }
    .info-label { font-size:0.72rem; text-transform:uppercase; letter-spacing:1px; color:var(--text-secondary); font-weight:700; margin-bottom:4px; }
    .info-value { font-weight:600; font-size:0.95rem; color:var(--text-primary); }
    .info-detail { font-size:0.8rem; color:var(--text-secondary); margin-top:2px; }

    /* Map placeholder */
    .map-placeholder {
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: var(--radius-md); overflow: hidden;
        height: 200px;
        display: flex; align-items: center; justify-content: center;
        color: var(--text-secondary); gap: 10px; font-size: 0.875rem;
        margin-bottom: 12px;
    }

    /* Form */
    .contact-form-card {
        background: var(--bg-card); border: 1px solid var(--border);
        border-radius: var(--radius-md); padding: 32px;
        position: relative;
    }
    .contact-form-card::before {
        content: ''; position: absolute; top: 0; left: 40px; right: 40px;
        height: 2px; background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }
    .contact-form-title { font-weight: 700; font-size: 1.1rem; margin-bottom: 4px; }
    .contact-form-sub { color: var(--text-secondary); font-size: 0.82rem; margin-bottom: 24px; }

    .field-block { margin-bottom: 16px; }
    .form-label { font-size:0.7rem; text-transform:uppercase; letter-spacing:1.2px; font-weight:700; color:var(--text-secondary); margin-bottom:6px; display:block; }

    .btn-send {
        width: 100%; background: var(--accent); color: var(--bg-deep);
        border: none; border-radius: var(--radius-sm); padding: 13px;
        font-weight: 700; font-size: 0.9rem; cursor: pointer;
        transition: all 0.3s; display: flex; align-items: center;
        justify-content: center; gap: 8px;
    }
    .btn-send:hover {
        background: #f5d465;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px var(--accent-glow);
    }

    .hours-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .hours-item {
        background: rgba(255,255,255,0.03); border: 1px solid var(--border);
        border-radius: var(--radius-sm); padding: 10px 14px;
        font-size: 0.8rem;
    }
    .hours-day { color: var(--text-secondary); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 2px; }
    .hours-time { font-weight: 600; color: var(--accent); }

    .reveal { opacity:0; transform:translateY(30px); transition:all 0.6s ease; }
    .reveal.visible { opacity:1; transform:translateY(0); }
</style>

<div class="container contact-section">
    <div class="fade-up">
        <div class="section-label">Fale Conosco</div>
        <h1 class="section-title">ENTRE EM<br><span style="color:var(--accent)">CONTATO</span></h1>
    </div>

    <div class="contact-grid mt-4">
        <!-- Left: Info -->
        <div class="fade-up">
            <div class="info-item">
                <div class="info-icon"><i class="bi bi-geo-alt-fill"></i></div>
                <div>
                    <div class="info-label">Endereço</div>
                    <div class="info-value">Centro de Treinamento Ferri</div>
                    <div class="info-detail">Rua Exemplo, 123 — Bairro, Cidade - SP</div>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="bi bi-whatsapp"></i></div>
                <div>
                    <div class="info-label">WhatsApp</div>
                    <div class="info-value">(18) 99999-0000</div>
                    <div class="info-detail">Seg a Sáb — 8h às 20h</div>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="bi bi-envelope-fill"></i></div>
                <div>
                    <div class="info-label">E-mail</div>
                    <div class="info-value">contato@ferrict.com.br</div>
                    <div class="info-detail">Respondemos em até 24h</div>
                </div>
            </div>

            <div class="info-item">
                <div class="info-icon"><i class="bi bi-instagram"></i></div>
                <div>
                    <div class="info-label">Instagram</div>
                    <div class="info-value">ferrict</div>
                    <div class="info-detail">Siga e acompanhe as novidades</div>
                </div>
            </div>

            <!-- Horários -->
            <div style="margin-top:20px">
                <div style="font-weight:700;font-size:0.9rem;margin-bottom:12px">
                    <i class="bi bi-clock" style="color:var(--accent)"></i> Horários de Funcionamento
                </div>
                <div class="hours-grid">
                    <div class="hours-item">
                        <div class="hours-day">Seg — Sex</div>
                        <div class="hours-time">06h — 22h</div>
                    </div>
                    <div class="hours-item">
                        <div class="hours-day">Sábado</div>
                        <div class="hours-time">08h — 18h</div>
                    </div>
                    <div class="hours-item">
                        <div class="hours-day">Domingo</div>
                        <div class="hours-time">Fechado</div>
                    </div>
                    <div class="hours-item">
                        <div class="hours-day">Feriados</div>
                        <div class="hours-time">Sob consulta</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Form -->
        <div class="fade-up delay-2">
            <div class="contact-form-card">
                <div class="contact-form-title">Envie uma Mensagem</div>
                <div class="contact-form-sub">Preencha o formulário e entraremos em contato em breve.</div>

                <div class="field-block">
                    <label class="form-label">Seu Nome</label>
                    <input type="text" class="form-control" placeholder="Nome completo">
                </div>
                <div class="field-block">
                    <label class="form-label">E-mail</label>
                    <input type="email" class="form-control" placeholder="seu@email.com">
                </div>
                <div class="field-block">
                    <label class="form-label">Assunto</label>
                    <select class="form-select">
                        <option value="">Selecione o assunto</option>
                        <option>Dúvidas sobre a aula experimental</option>
                        <option>Informações sobre mensalidades</option>
                        <option>Horários disponíveis</option>
                        <option>Outro assunto</option>
                    </select>
                </div>
                <div class="field-block">
                    <label class="form-label">Mensagem</label>
                    <textarea class="form-control" rows="4" placeholder="Escreva sua mensagem..." style="resize:vertical"></textarea>
                </div>

                <button type="button" class="btn-send">
                    <i class="bi bi-send-fill"></i> Enviar Mensagem
                </button>

                <div style="margin-top:20px;text-align:center">
                    <p style="color:var(--text-secondary);font-size:0.78rem;margin-bottom:10px">Ou agende direto pelo link:</p>
                    <a href="/Agendamento/Create" class="btn-outline-gold" style="display:inline-flex;align-items:center;gap:8px;padding:10px 24px;font-size:0.85rem">
                        <i class="bi bi-calendar-check"></i> Agendar Aula Grátis
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>const reveals = document.querySelectorAll('.reveal');
    const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }});
    }, { threshold: 0.1 });
    reveals.forEach(r => obs.observe(r));

    // Send button feedback
    document.querySelector('.btn-send')?.addEventListener('click', function() {
        this.innerHTML = '<i class="bi bi-check-lg"></i> Mensagem enviada!';
        this.style.background = 'var(--success)';
        this.style.color = '#fff';
        setTimeout(() => {
            this.innerHTML = '<i class="bi bi-send-fill"></i> Enviar Mensagem';
            this.style.background = '';
            this.style.color = '';
        }, 3000);
    });</script>
