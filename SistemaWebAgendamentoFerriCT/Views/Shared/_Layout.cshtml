<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Ferri CT</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        :root {
            /* Surface */
            --bg-deep:       #07070A;
            --bg-surface:    #0F0F14;
            --bg-card:       #15151C;
            --bg-elevated:   #1B1B23;
            --border:        rgba(255,255,255,0.07);
            --border-strong: rgba(255,255,255,0.12);

            /* Accent — Signal Yellow */
            --accent:        #FFCC00;
            --accent-hover:  #FFDA33;
            --accent-soft:   rgba(255,204,0,0.08);
            --accent-dim:    rgba(255,204,0,0.15);
            --accent-glow:   rgba(255,204,0,0.35);

            /* Text */
            --text-primary:   #F4F3EE;
            --text-secondary: #8A8A95;
            --text-muted:     #8A8A95;

            /* States */
            --danger:  #E05050;
            --success: #4CAF82;
            --warning: #F59E0B;

            /* Radius */
            --radius-sm: 8px;
            --radius-md: 14px;
            --radius-lg: 22px;

            /* Shadow */
            --shadow-sm: 0 2px 8px rgba(0,0,0,0.3);
            --shadow-md: 0 8px 24px rgba(0,0,0,0.35);
            --shadow-lg: 0 18px 48px rgba(0,0,0,0.5);
            --shadow-accent: 0 8px 28px rgba(255,204,0,0.25);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html, body {
            background: var(--bg-deep);
            color: var(--text-primary);
            font-family: 'DM Sans', sans-serif;
            font-size: 15px;
            min-height: 100vh;
            overflow-x: hidden;
        }

            body::before {
                content: '';
                position: fixed;
                inset: 0;
                background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
                pointer-events: none;
                z-index: 0;
            }

        /* ─── NAVBAR ─── */
        .ferri-nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            height: 64px;
            background: rgba(8,8,9,0.85);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
        }

        .nav-brand {
            font-family: 'Bebas Neue', sans-serif;
            font-size: 1.8rem;
            letter-spacing: 3px;
            color: var(--accent);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .nav-brand span {
                color: var(--text-primary);
            }

            .nav-brand .dot {
                width: 8px;
                height: 8px;
                background: var(--accent);
                border-radius: 50%;
                display: inline-block;
                animation: pulse-dot 2s infinite;
            }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 2rem;
            list-style: none;
        }

            .nav-links a {
                color: var(--text-secondary);
                text-decoration: none;
                font-weight: 500;
                font-size: 0.9rem;
                letter-spacing: 0.5px;
                transition: color 0.2s;
                position: relative;
            }

                .nav-links a::after {
                    content: '';
                    position: absolute;
                    bottom: -4px;
                    left: 0;
                    width: 0;
                    height: 1px;
                    background: var(--accent);
                    transition: width 0.3s;
                }

                .nav-links a:hover {
                    color: var(--text-primary);
                }

                    .nav-links a:hover::after {
                        width: 100%;
                    }

        .nav-cta {
            background: var(--accent);
            color: var(--bg-deep) !important;
            padding: 8px 20px;
            border-radius: var(--radius-sm);
            font-weight: 600 !important;
            font-size: 0.85rem !important;
            transition: all 0.2s !important;
        }

            .nav-cta:hover {
                background: var(--accent-hover) !important;
                transform: translateY(-1px);
                box-shadow: 0 6px 20px var(--accent-glow);
            }

            .nav-cta::after {
                display: none !important;
            }

        /* ─── DROPDOWN PERFIL ─── */
        .nav-user {
            position: relative;
        }

        .nav-user-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 6px 14px 6px 6px;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--text-primary);
            text-decoration: none;
        }

            .nav-user-btn:hover {
                border-color: rgba(255,204,0,0.3);
                background: rgba(255,204,0,0.06);
                color: var(--text-primary);
            }

        .nav-user-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: var(--accent-dim);
            border: 1px solid rgba(255,204,0,0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.72rem;
            font-weight: 700;
            color: var(--accent);
            font-family: 'DM Sans', sans-serif;
            flex-shrink: 0;
        }

        .nav-user-name {
            font-size: 0.82rem;
            font-weight: 600;
            max-width: 120px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .nav-user-chevron {
            font-size: 0.72rem;
            color: var(--text-secondary);
            transition: transform 0.2s;
        }

        .nav-user.open .nav-user-chevron {
            transform: rotate(180deg);
        }

        /* Dropdown menu */
        .nav-dropdown {
            position: absolute;
            top: calc(100% + 10px);
            right: 0;
            width: 220px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            box-shadow: 0 16px 48px rgba(0,0,0,0.5);
            overflow: hidden;
            opacity: 0;
            transform: translateY(-8px) scale(0.97);
            pointer-events: none;
            transition: all 0.2s ease;
            z-index: 100;
        }

        .nav-user.open .nav-dropdown {
            opacity: 1;
            transform: translateY(0) scale(1);
            pointer-events: all;
        }

        .dropdown-header {
            padding: 14px 16px;
            border-bottom: 1px solid var(--border);
            background: rgba(255,255,255,0.02);
        }

        .dropdown-header-name {
            font-weight: 700;
            font-size: 0.875rem;
            color: var(--text-primary);
        }

        .dropdown-header-tag {
            font-size: 0.72rem;
            color: var(--text-secondary);
            margin-top: 2px;
            display: flex;
            align-items: center;
            gap: 5px;
        }

            .dropdown-header-tag::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: var(--success);
            }

        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 16px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 500;
            transition: all 0.15s;
            border-bottom: 1px solid var(--border);
        }

            .dropdown-item:last-child {
                border: none;
            }

            .dropdown-item i {
                width: 18px;
                text-align: center;
                font-size: 0.95rem;
            }

            .dropdown-item:hover {
                background: rgba(255,255,255,0.04);
                color: var(--text-primary);
            }

                .dropdown-item:hover i {
                    color: var(--accent);
                }

        .dropdown-item-logout {
            color: #ff8a8a !important;
        }

            .dropdown-item-logout:hover {
                background: rgba(224,80,80,0.08) !important;
                color: #ff8a8a !important;
            }

            .dropdown-item-logout i {
                color: #ff8a8a !important;
            }

        /* ─── MAIN ─── */
        .main-wrapper {
            padding-top: 64px;
            min-height: 100vh;
            position: relative;
            z-index: 1;
        }

        /* ─── SHARED COMPONENTS ─── */
        .glass {
            background: rgba(24,24,29,0.8);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
        }

        .glass-sm {
            background: rgba(24,24,29,0.6);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
        }

        .btn-gold {
            background: var(--accent);
            color: var(--bg-deep);
            font-weight: 700;
            border: none;
            border-radius: var(--radius-sm);
            padding: 10px 24px;
            transition: all 0.25s;
            letter-spacing: 0.3px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .btn-gold:hover {
                background: var(--accent-hover);
                color: var(--bg-deep);
                transform: translateY(-2px);
                box-shadow: 0 8px 24px var(--accent-glow);
            }

        .btn-outline-gold {
            background: transparent;
            color: var(--accent);
            border: 1px solid var(--accent);
            border-radius: var(--radius-sm);
            padding: 10px 24px;
            font-weight: 600;
            transition: all 0.25s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .btn-outline-gold:hover {
                background: var(--accent-dim);
                color: var(--accent);
            }

        .form-control, .form-select {
            background: rgba(255,255,255,0.04) !important;
            border: 1px solid var(--border) !important;
            color: var(--text-primary) !important;
            border-radius: var(--radius-sm) !important;
            padding: 12px 16px !important;
            transition: border-color 0.2s, box-shadow 0.2s !important;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--accent) !important;
                box-shadow: 0 0 0 3px var(--accent-dim) !important;
                outline: none !important;
            }

            .form-control::placeholder {
                color: var(--text-secondary) !important;
            }

            .form-select option {
                background: var(--bg-card);
            }

        .form-label {
            color: var(--text-secondary);
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .ferri-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 6px;
        }

            .ferri-table thead th {
                color: var(--text-secondary);
                font-size: 0.75rem;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                padding: 10px 16px;
                border: none;
                font-weight: 600;
            }

            .ferri-table tbody tr {
                background: var(--bg-card);
                border-radius: var(--radius-sm);
                transition: all 0.2s;
            }

                .ferri-table tbody tr:hover {
                    background: rgba(255,204,0,0.06);
                    transform: translateX(4px);
                }

            .ferri-table tbody td {
                padding: 14px 16px;
                border: none;
                vertical-align: middle;
            }

                .ferri-table tbody td:first-child {
                    border-radius: var(--radius-sm) 0 0 var(--radius-sm);
                }

                .ferri-table tbody td:last-child {
                    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
                }

        .badge-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 999px;
            font-size: 0.75rem;
            font-weight: 600;
        }

            .badge-status::before {
                content: '';
                width: 6px;
                height: 6px;
                border-radius: 50%;
                background: currentColor;
            }

        .badge-confirmado {
            color: var(--success);
            background: rgba(76,175,130,0.12);
        }

        .badge-pendente {
            color: var(--accent);
            background: var(--accent-dim);
        }

        .badge-cancelado {
            color: var(--danger);
            background: rgba(224,80,80,0.12);
        }

        .ferri-divider {
            height: 1px;
            background: var(--border);
            margin: 24px 0;
        }

        
    .footer-admin-link {
        color: var(--text-secondary);
        font-size: 0.75rem;
        opacity: 0.45;
        text-decoration: none;
        transition: opacity 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
    }
    .footer-admin-link:hover {
        opacity: 1;
        color: var(--accent);
    }

    .ferri-footer {
        border-top: 1px solid var(--border);
        padding: 1.75rem 2rem;
        color: var(--text-secondary);
        font-size: 0.8rem;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 10px 24px;
    }

    .ferri-footer > span {
        flex: 1 1 auto;
        min-width: 0;
    }

    .ferri-footer strong {
        color: var(--accent);
    }

    @@media (max-width: 768px) {
        .ferri-footer {
            flex-direction: column;
            text-align: center;
            padding: 1.25rem 1rem;
            gap: 10px;
            font-size: 0.75rem;
            line-height: 1.5;
        }
        .ferri-footer > span { flex: 0 0 auto; }
        .footer-admin-link {
            font-size: 0.72rem;
            opacity: 0.6;
        }
    }

    @@media (max-width: 480px) {
        .ferri-footer {
            padding: 1rem 0.75rem;
            font-size: 0.72rem;
        }
    }

        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-deep);
        }

        ::-webkit-scrollbar-thumb {
            background: #333;
            border-radius: 3px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: var(--accent);
            }

        @@keyframes pulse-dot {
            0%, 100% {
                box-shadow: 0 0 0 0 var(--accent-glow);
            }

            50% {
                box-shadow: 0 0 0 6px transparent;
            }
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @@keyframes slideRight {
            from {
                opacity: 0;
                transform: translateX(-20px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .fade-up {
            animation: fadeUp 0.6s ease forwards;
        }

        .fade-in {
            animation: fadeIn 0.6s ease forwards;
        }

        .slide-right {
            animation: slideRight 0.5s ease forwards;
        }

        .delay-1 {
            animation-delay: 0.1s;
            opacity: 0;
        }

        .delay-2 {
            animation-delay: 0.2s;
            opacity: 0;
        }

        .delay-3 {
            animation-delay: 0.3s;
            opacity: 0;
        }

        .delay-4 {
            animation-delay: 0.4s;
            opacity: 0;
        }

        .delay-5 {
            animation-delay: 0.5s;
            opacity: 0;
        }

        @@media (max-width: 768px) {
            .ferri-nav {
                padding: 0 1rem;
            }

            .nav-links {
                display: none;
            }
        }
    </style>
</head>
<body>

    <nav class="ferri-nav">
        <a href="/" class="nav-brand">
            <span class="dot"></span>FERRI<span>&nbsp;CT</span>
        </a>

        <ul class="nav-links">
            <li><a href="/">Início</a></li>
            <li><a href="/Home/About">Sobre</a></li>
            <li><a href="/Home/Contact">Contato</a></li>

            @if (Session["ClienteId"] != null)
            {
                @* ── DROPDOWN PERFIL ── *@
                var nomeCompleto = Session["ClienteNome"] as string ?? "Aluno";
                var partes = nomeCompleto.Trim().Split(' ');
                var iniciais = partes.Length >= 2
                    ? (partes[0][0].ToString() + partes[partes.Length - 1][0].ToString()).ToUpper()
                    : partes[0].Substring(0, Math.Min(2, partes[0].Length)).ToUpper();
                var primeiroNome = partes[0];

                <li class="nav-user" id="navUser">
                    <a href="#" class="nav-user-btn" onclick="toggleDropdown(event)">
                        <div class="nav-user-avatar">@iniciais</div>
                        <span class="nav-user-name">@primeiroNome</span>
                        <i class="bi bi-chevron-down nav-user-chevron"></i>
                    </a>

                    <div class="nav-dropdown">
                        <div class="dropdown-header">
                            <div class="dropdown-header-name">@nomeCompleto</div>
                            <div class="dropdown-header-tag">Aluno ativo</div>
                        </div>
                        <a href="/Cliente/Perfil" class="dropdown-item">
                            <i class="bi bi-person-fill"></i> Meu Perfil
                        </a>
                        <a href="/Agendamento/Create" class="dropdown-item">
                            <i class="bi bi-calendar-check-fill"></i> Agendar Aula
                        </a>
                        <a href="/Cliente/Editar" class="dropdown-item">
                            <i class="bi bi-pencil-fill"></i> Editar Dados
                        </a>
                        <a href="@Url.Action("Logout", "Cliente")" class="dropdown-item dropdown-item-logout">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </a>
                    </div>
                </li>
            }
            else
            {

                <li><a href="/Cliente/Login">Área do Aluno</a></li>

                <li><a href="/Agendamento/Create" class="nav-cta">Agendar Aula</a></li>

            }
        </ul>

        <!-- Mobile toggle -->
        <button class="btn btn-sm d-md-none" style="background:var(--border);color:var(--text-primary);border:none"
                onclick="document.getElementById('mob-menu').classList.toggle('d-none')">
            <i class="bi bi-list fs-5"></i>
        </button>
    </nav>

    <!-- Mobile Menu -->
    <div id="mob-menu" class="d-none d-md-none" style="position:fixed;top:64px;left:0;right:0;background:var(--bg-surface);border-bottom:1px solid var(--border);z-index:999;padding:1rem 2rem">
        <a href="/" class="d-block py-2 text-decoration-none" style="color:var(--text-secondary)">Início</a>
        <a href="/Home/About" class="d-block py-2 text-decoration-none" style="color:var(--text-secondary)">Sobre</a>
        <a href="/Home/Contact" class="d-block py-2 text-decoration-none" style="color:var(--text-secondary)">Contato</a>
        @if (Session["ClienteId"] != null)
        {
            <a href="/Cliente/Perfil" class="d-block py-2 text-decoration-none" style="color:var(--text-secondary)"><i class="bi bi-person me-2"></i>Meu Perfil</a>
            <a href="/Agendamento/Create" class="d-block py-2 text-decoration-none" style="color:var(--text-secondary)"><i class="bi bi-calendar-check me-2"></i>Agendar Aula</a>
            <a href="@Url.Action("Logout", "Cliente")" class="d-block py-2 text-decoration-none" style="color:#ff8a8a"><i class="bi bi-box-arrow-right me-2"></i>Sair</a>
        }
        else
        {
            <a href="/Cliente/Login" class="d-block py-2 text-decoration-none" style="color:var(--text-secondary)">Área do Aluno</a>
            <a href="/Agendamento/Create" class="btn btn-gold w-100 mt-2">Agendar Aula</a>
        }
    </div>

    <div class="main-wrapper">
        @RenderBody()
    </div>

    <footer class="ferri-footer">
        <span>&copy; @DateTime.Now.Year <strong>Ferri CT</strong> — Todos os direitos reservados.</span>
        <a href="/Admin/Login" class="footer-admin-link" title="Área Administrativa">
            <i class="bi bi-shield-lock"></i> Admin
        </a>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleDropdown(e) {
            e.preventDefault();
            document.getElementById('navUser').classList.toggle('open');
        }
        // Fecha ao clicar fora
        document.addEventListener('click', function (e) {
            const navUser = document.getElementById('navUser');
            if (navUser && !navUser.contains(e.target)) {
                navUser.classList.remove('open');
            }
        });
    </script>
</body>
</html>
