<?xml version="1.0" encoding="utf-8"?>
<!--
  MODELO. Copie este arquivo para Web.secrets.config (sem .example) na mesma pasta
  e preencha com suas credenciais reais. O arquivo Web.secrets.config NÃO é versionado.

  Onde obter cada valor:
    AccessToken      → painel MP Developers → Sua aplicação → Credenciais → "Token de acesso" (TEST-... no sandbox)
    PublicKey        → painel MP Developers → Sua aplicação → Credenciais → "Chave pública" (TEST-... no sandbox)
    WebhookSecret    → painel MP Developers → Sua aplicação → Webhooks → "Chave secreta" (gerada após salvar a URL do webhook)
    NotificationUrl  → URL pública do túnel (Cloudflare/ngrok) apontando para /Pagamento/Webhook
    BackUrlBase      → URL pública base do site (em dev, mesma do túnel; em prod, seu domínio com HTTPS)

  IMPORTANTE: Em produção, troque as credenciais TEST-* pelas APP_USR-* e mude a NotificationUrl
  para o domínio real com HTTPS.
-->
<appSettings>
  <add key="MercadoPago:AccessToken" value="TEST-0000000000000000-000000-00000000000000000000000000000000-000000000" />
  <add key="MercadoPago:PublicKey" value="TEST-00000000-0000-0000-0000-000000000000" />
  <add key="MercadoPago:WebhookSecret" value="cole-aqui-a-chave-secreta-do-webhook" />
  <add key="MercadoPago:NotificationUrl" value="https://seu-tunel.trycloudflare.com/Pagamento/Webhook" />
  <add key="MercadoPago:BackUrlBase" value="https://seu-tunel.trycloudflare.com" />
</appSettings>
